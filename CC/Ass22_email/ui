<apex:page controller="EmailController2"
           sidebar="false">

    <apex:form enctype="multipart/form-data">

        <apex:pageBlock title="Send Email">

            <apex:pageMessages/>

            <apex:pageBlockSection columns="1">

                <apex:inputText value="{!toEmail}"
                                label="Recipient Email"/>

                <apex:inputText value="{!subject}"
                                label="Subject"/>

                <apex:inputTextarea value="{!body}"
                                    label="Message"/>

                <!-- Choose File -->
                <apex:inputFile value="{!fileBody}"
                                filename="{!fileName}"/>

            </apex:pageBlockSection>

            <apex:pageBlockButtons>

                <apex:commandButton value="Send Email"
                                    action="{!sendMail}"/>

            </apex:pageBlockButtons>

        </apex:pageBlock>

    </apex:form>

</apex:page>
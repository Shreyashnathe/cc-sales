public class EmailController {

    // Send Email Without Attachment
    public static void sendMail() {

        Messaging.SingleEmailMessage mail =
            new Messaging.SingleEmailMessage();

        mail.setToAddresses(
            new String[] {'natheshreyash@gmail.com'}
        );

        mail.setSubject('Salesforce Email');

        mail.setPlainTextBody(
            'Hello, Email sent successfully using Apex.'
        );

        Messaging.sendEmail(
            new Messaging.SingleEmailMessage[] {mail}
        );

        System.debug('Email Sent Successfully');
    }


    // Send Email With Attachment
    public static void sendMailWithAttachment() {

        Messaging.SingleEmailMessage mail =
            new Messaging.SingleEmailMessage();

        mail.setToAddresses(
            new String[] {'natheshreyash@gmail.com'}
        );

        mail.setSubject('Salesforce Email With Attachment');

        mail.setPlainTextBody(
            'Hello, this email contains attachment.'
        );

        // Attachment
        Messaging.EmailFileAttachment file =
            new Messaging.EmailFileAttachment();

        file.setFileName('demo.txt');

        file.setBody(
            Blob.valueOf('This is Salesforce attachment file.')
        );

        mail.setFileAttachments(
            new Messaging.EmailFileAttachment[] {file}
        );

        Messaging.sendEmail(
            new Messaging.SingleEmailMessage[] {mail}
        );

        System.debug('Email With Attachment Sent');
    }
}